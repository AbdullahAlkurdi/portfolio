# Public Site URL
NEXT_PUBLIC_SITE_URL=https://abdullahalkurdi.dev

# Firebase Client SDK (public - used in admin dashboard)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK (server-side only - never exposed to client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Google Drive Media Storage (server-side only - never exposed to client)
# Uses OAuth 2.0 with your personal Google account via refresh token.
# Run "node scripts/setup-drive-oauth.mjs" to generate these values.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Optional sub-folder IDs for organized media storage:
GOOGLE_DRIVE_PROFILE_FOLDER_ID=
GOOGLE_DRIVE_PROJECTS_FOLDER_ID=
GOOGLE_DRIVE_CERTIFICATIONS_FOLDER_ID=
GOOGLE_DRIVE_DOCUMENTS_FOLDER_ID=

# Admin authentication
NEXT_PUBLIC_ADMIN_EMAIL=abdullah.h.alkurdi@gmail.com
